generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  PENDING_EMAIL
  ACTIVE
  SUSPENDED
  DELETED
}

model User {
  id                      String                   @id @default(cuid())
  username                String                   @unique
  email                   String?                  @unique
  emailVerifiedAt         DateTime?
  passwordHash            String
  nickname                String?
  displayName             String?
  role                    UserRole                 @default(USER)
  status                  UserStatus               @default(PENDING_EMAIL)
  tags                    String[]                 @default([])
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  lastLoginAt             DateTime?
  lastSeenAt              DateTime?
  failedLoginCount        Int                      @default(0)
  lockedUntil             DateTime?
  avatar                  String?
  phone                   String?                  @unique
  quickLoginToken         String?
  searchSessions          SearchSession[]
  userProfile             UserProfile?
  newsletterDeliveries    NewsletterDeliveryLog[]
  compareReports          CompareReport[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  invitationCodeUses      InvitationCodeUse[]
  quickLoginDevices       QuickLoginDevice[]
  maintenanceJobs         MaintenanceJob[]
  maintenanceSchedules    MaintenanceSchedule[]
  createdInvitationCodes  InvitationCode[]         @relation("InvitationCodesCreated")
  auditLogsAuthored       UserAuditLog[]           @relation("UserAuditActor")
  auditLogsReceived       UserAuditLog[]           @relation("UserAuditTarget")

  @@index([role])
  @@index([status])
  @@index([createdAt])
}

model InvitationCode {
  id          String              @id @default(cuid())
  code        String              @unique
  type        String              @default("REGISTRATION")
  maxUsages   Int                 @default(1)
  usedCount   Int                 @default(0)
  expiresAt   DateTime
  channel     String?
  note        String?
  createdById String?
  createdAt   DateTime            @default(now())
  createdBy   User?               @relation("InvitationCodesCreated", fields: [createdById], references: [id], onDelete: SetNull)
  uses        InvitationCodeUse[]

  @@index([expiresAt])
  @@index([channel])
  @@index([createdById])
}

model InvitationCodeUse {
  id               String         @id @default(cuid())
  invitationCodeId String
  userId           String
  usedAt           DateTime       @default(now())
  invitationCode   InvitationCode @relation(fields: [invitationCodeId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([invitationCodeId, userId])
  @@index([userId])
  @@index([usedAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model UserAuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?
  targetUserId String?
  action       String
  metadata     Json?
  createdAt    DateTime @default(now())
  actor        User?    @relation("UserAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  target       User?    @relation("UserAuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([action])
  @@index([createdAt])
}

model AuthRateLimitEvent {
  id        String   @id @default(cuid())
  key       String
  action    String
  createdAt DateTime @default(now())

  @@index([key, action, createdAt])
  @@index([createdAt])
}

model QuickLoginDevice {
  id         String    @id @default(cuid())
  userId     String
  deviceName String?
  tokenHash  String    @unique
  userAgent  String?
  ipHash     String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastUsedAt DateTime?
  revokedAt  DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([revokedAt])
  @@index([lastUsedAt])
}

model MaintenanceJob {
  id                String              @id @default(cuid())
  kind              String
  status            String              @default("queued")
  dryRun            Boolean             @default(true)
  triggerSource     String              @default("manual")
  requestedById     String?
  sourceJobId       String?
  retryCount        Int                 @default(0)
  targetPersonIds   String[]            @default([])
  options           Json                @default("{}")
  command           String?
  progressTotal     Int                 @default(0)
  progressDone      Int                 @default(0)
  errorMessage      String?
  startedAt         DateTime?
  completedAt       DateTime?
  cancelRequestedAt DateTime?
  canceledById      String?
  cancelReason      String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  requestedBy       User?               @relation(fields: [requestedById], references: [id], onDelete: SetNull)
  logs              MaintenanceJobLog[]

  @@index([kind])
  @@index([status])
  @@index([triggerSource])
  @@index([requestedById])
  @@index([sourceJobId])
  @@index([canceledById])
  @@index([cancelRequestedAt])
  @@index([createdAt])
}

model MaintenanceJobLog {
  id        String         @id @default(cuid())
  jobId     String
  level     String         @default("info")
  message   String
  metadata  Json?
  createdAt DateTime       @default(now())
  job       MaintenanceJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
  @@index([level])
}

model MaintenanceSchedule {
  id              String    @id @default(cuid())
  name            String
  enabled         Boolean   @default(false)
  kind            String
  dryRun          Boolean   @default(true)
  targetPersonIds String[]  @default([])
  options         Json      @default("{}")
  intervalHours   Int       @default(24)
  nextRunAt       DateTime?
  lastRunAt       DateTime?
  lastJobId       String?
  runCount        Int       @default(0)
  createdById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([enabled, nextRunAt])
  @@index([kind])
  @@index([createdById])
  @@index([lastJobId])
}

model People {
  id                  String   @id @default(cuid())
  qid                 String   @unique
  name                String
  aliases             String[]
  description         String?
  whyImportant        String? // AI贡献总结：核心贡献 + 数据来源
  aiContributionScore Float    @default(5) // AI 贡献度评分 (0-10, 支持小数)
  avatarUrl           String?
  gender              String? // "male", "female", "other", "unknown"
  country             String? // ISO 3166-1 alpha-2, e.g. "CN", "US"
  occupation          String[]
  organization        String[]
  officialLinks       Json     @default("[]")
  sourceWhitelist     String[]
  status              String   @default("pending")
  completeness        Int      @default(0)

  // 新增：影响力评估相关字段
  topics         String[] // AI话题标签：RAG, Agent, 推理, 多模态, 对齐, Scaling 等
  topicRanks     Json? // 话题排名：{ "Scaling": 1, "Agent": 3 }
  topicDetails   Json? // 话题详情含金句：[{ topic, rank, quote?: { text, source, url } }]
  highlights     Json? // 卡片亮点：[{icon: "📄", text: "论文标题"}, ...]
  roleCategory   String? // 角色分类：researcher, founder, engineer, professor, evangelist
  influenceScore Float    @default(0) // 综合影响力分数
  quotes         Json? // 代表语录：[{ text, source, url, year, importance }]

  // 新增：人物详情页展示字段
  currentTitle String? // 当前职位标题，如 "Co-founder & Chief Scientist @ SSI"
  products     Json? // 代表作品：[{ name, org, year, description, url, icon?, stats? }]
  education    Json? // 教育背景：[{ school, degree, field?, year?, advisor? }]

  // 学术指标 (来自 OpenAlex)
  citationCount Int     @default(0) // 论文总引用数
  hIndex        Int     @default(0) // h-index
  openalexId    String? // OpenAlex author ID

  // GitHub 指标
  githubStars Int @default(0) // GitHub 总 stars

  // 访问统计
  viewCount       Int @default(0) // 总访问次数
  weeklyViewCount Int @default(0) // 本周访问次数

  // 增量更新：记录每个数据源的上次获取时间
  // { exa: "2026-01-01T00:00:00Z", grok: "2026-01-01T00:00:00Z", ... }
  lastFetchedAt Json @default("{}")

  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  cards                Card[]
  roles                PersonRole[]
  rawPoolItems         RawPoolItem[]
  paperEntityReviews   PaperEntityReview[]
  activityEvents       ActivityEvent[]
  youtubeTranscripts   YouTubeTranscript[]
  searchSessions       SearchSession[]
  pageViews            PageView[]
  relations            PersonRelation[]         @relation("PersonRelations")
  relatedTo            PersonRelation[]         @relation("RelatedPersons")
  advisedRoles         PersonRole[]             @relation("RoleAdvisor") // 作为导师的履历记录
  courses              Course[] // 开设/主讲的课程
  influenceScoreAudits InfluenceScoreAuditLog[]
  productContributions ProductContributor[] // 参与的作品/产品

  @@index([name])
  @@index([status])
  @@index([influenceScore])
  @@index([roleCategory])
  @@index([status, influenceScore])
}

model Organization {
  id                 String              @id @default(cuid())
  name               String
  nameZh             String?
  type               String
  wikidataQid        String?             @unique
  description        String?
  aliases            String[]            @default([]) // 合并旧名/别名，防止重新碎片化
  roles              PersonRole[]
  companySources     CompanySource[]
  companyThreadLinks CompanyThreadLink[]
  paperEntityReviews PaperEntityReview[]

  @@index([name])
  @@index([wikidataQid])
}

model CompanySource {
  id                         String       @id @default(cuid())
  organizationId             String
  sourceKind                 String
  role                       String
  title                      String
  url                        String
  finalUrl                   String?
  canonicalUrl               String
  urlHash                    String       @unique
  text                       String
  summary                    String?
  publishedAt                DateTime?
  fetchedAt                  DateTime?
  confidence                 Float        @default(0.8)
  readinessUse               String       @default("company_page_only")
  excludedFromTopicReadiness Boolean      @default(true)
  companyPageOnly            Boolean      @default(true)
  metadata                   Json?
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt
  organization               Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([role])
  @@index([sourceKind])
  @@index([publishedAt])
  @@index([fetchedAt])
  @@index([organizationId, publishedAt])
  @@index([sourceKind, publishedAt])
}

model CompanyThreadLink {
  id                         String       @id @default(cuid())
  organizationId             String
  threadSlug                 String
  threadTitle                String
  relationType               String
  summary                    String
  evidenceSourceIds          String[]     @default([])
  confidence                 Float        @default(0.8)
  excludedFromTopicReadiness Boolean      @default(true)
  countsTowardTopicReadiness Boolean      @default(false)
  metadata                   Json?
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt
  organization               Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, threadSlug, relationType])
  @@index([organizationId])
  @@index([threadSlug])
  @@index([relationType])
}

model PersonRole {
  id             String       @id @default(cuid())
  personId       String
  organizationId String
  role           String
  roleZh         String?
  startDate      DateTime?
  endDate        DateTime?
  source         String       @default("wikidata")
  confidence     Float        @default(1.0)
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  person         People       @relation(fields: [personId], references: [id], onDelete: Cascade)
  // 导师关联（用于教育经历）
  advisorId      String?
  advisor        People?      @relation("RoleAdvisor", fields: [advisorId], references: [id], onDelete: SetNull)

  @@unique([personId, organizationId, role, startDate])
  @@index([personId])
  @@index([organizationId])
  @@index([advisorId])
}

model Card {
  id           String    @id @default(cuid())
  personId     String
  type         String
  title        String
  content      String
  tags         String[]
  sourceUrl    String?
  importance   Int       @default(5)
  generationId String?
  isActive     Boolean   @default(true)
  archivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  person       People    @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@index([personId, isActive])
  @@index([generationId])
  @@index([type])
}

model RawPoolItem {
  id                     String                  @id @default(cuid())
  personId               String
  sourceType             String
  url                    String
  urlHash                String                  @unique
  contentHash            String
  title                  String
  text                   String
  publishedAt            DateTime?
  metadata               Json?
  fetchStatus            String                  @default("success")
  errorCode              String?
  fetchedAt              DateTime                @default(now())
  processed              Boolean                 @default(false)
  person                 People                  @relation(fields: [personId], references: [id], onDelete: Cascade)
  activityEvent          ActivityEvent?
  knowledgeThreadSources KnowledgeThreadSource[]
  paperDocument          PaperDocument?
  paperEntityReviews     PaperEntityReview[]
  productEvidenceSources ProductEvidenceSource[]
  captionTranscripts     YouTubeTranscript[]     @relation("CaptionTranscripts")
  videoTranscripts       YouTubeTranscript[]     @relation("VideoTranscripts")

  @@index([personId])
  @@index([sourceType])
  @@index([personId, sourceType, publishedAt])
  @@index([personId, publishedAt])
  @@index([fetchStatus, fetchedAt])
}

model PaperDocument {
  id             String         @id @default(cuid())
  sourceItemId   String?        @unique
  openalexId     String?
  doi            String?
  title          String
  abstract       String?
  pdfUrl         String?
  landingPageUrl String?
  authors        Json?
  venue          String?
  citationCount  Int            @default(0)
  status         String         @default("metadata_only")
  parseVersion   String?
  pageCount      Int?
  textHash       String?
  parseError     String?
  parsedAt       DateTime?
  metadata       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  sourceItem     RawPoolItem?   @relation(fields: [sourceItemId], references: [id], onDelete: SetNull)
  sections       PaperSection[]
  chunks         PaperChunk[]
  figures        PaperFigure[]

  @@index([openalexId])
  @@index([doi])
  @@index([status])
  @@index([parsedAt])
}

model PaperSection {
  id          String        @id @default(cuid())
  paperId     String
  sectionType String
  title       String
  text        String
  pageStart   Int?
  pageEnd     Int?
  orderIndex  Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  paper       PaperDocument @relation(fields: [paperId], references: [id], onDelete: Cascade)
  chunks      PaperChunk[]

  @@unique([paperId, orderIndex])
  @@index([paperId])
  @@index([sectionType])
  @@index([paperId, sectionType])
}

model PaperChunk {
  id            String        @id @default(cuid())
  paperId       String
  sectionId     String?
  text          String
  pageNumber    Int?
  chunkIndex    Int
  anchorHint    Json?
  embeddingId   String?
  tokenEstimate Int           @default(0)
  textHash      String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  paper         PaperDocument @relation(fields: [paperId], references: [id], onDelete: Cascade)
  section       PaperSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  @@unique([paperId, chunkIndex])
  @@index([paperId])
  @@index([sectionId])
  @@index([pageNumber])
  @@index([textHash])
}

model PaperFigure {
  id         String        @id @default(cuid())
  paperId    String
  label      String
  caption    String?
  pageNumber Int?
  bbox       Json?
  imagePath  String?
  orderIndex Int
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  paper      PaperDocument @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@unique([paperId, orderIndex])
  @@index([paperId])
  @@index([pageNumber])
}

model PaperEntityReview {
  id                      String        @id @default(cuid())
  sourceItemId            String
  entityName              String
  entityKind              String // person | organization
  mentionType             String // author | affiliation | text_mention
  matchReason             String
  confidence              Float         @default(0.6)
  candidatePeople         Json?
  candidateOrganizations  Json?
  reviewStatus            String        @default("needs_review") // needs_review | confirmed | rejected
  confirmedPersonId       String?
  confirmedOrganizationId String?
  evidenceQuote           String?
  metadata                Json?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  sourceItem              RawPoolItem   @relation(fields: [sourceItemId], references: [id], onDelete: Cascade)
  confirmedPerson         People?       @relation(fields: [confirmedPersonId], references: [id], onDelete: SetNull)
  confirmedOrganization   Organization? @relation(fields: [confirmedOrganizationId], references: [id], onDelete: SetNull)

  @@unique([sourceItemId, entityKind, mentionType, entityName])
  @@index([sourceItemId])
  @@index([entityKind])
  @@index([reviewStatus])
  @@index([confirmedPersonId])
  @@index([confirmedOrganizationId])
  @@index([entityKind, reviewStatus, confidence])
}

model YouTubeTranscript {
  id            String       @id @default(cuid())
  personId      String
  videoId       String
  url           String
  lang          String?
  segmentsText  String       @db.Text
  segmentCount  Int
  durationMs    Int?
  source        String       @default("supadata")
  fetchedAt     DateTime     @default(now())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  person        People       @relation(fields: [personId], references: [id], onDelete: Cascade)
  captionItemId String?
  captionItem   RawPoolItem? @relation("CaptionTranscripts", fields: [captionItemId], references: [id], onDelete: SetNull)
  sourceItemId  String?
  sourceItem    RawPoolItem? @relation("VideoTranscripts", fields: [sourceItemId], references: [id], onDelete: SetNull)

  @@unique([personId, videoId])
  @@index([personId])
  @@index([videoId])
  @@index([captionItemId])
  @@index([sourceItemId])
  @@index([fetchedAt])
}

model KnowledgeThread {
  id                 String                  @id @default(cuid())
  slug               String                  @unique
  title              String
  summary            String
  whyNow             String?
  status             String                  @default("draft")
  priorityScore      Float                   @default(0)
  confidence         Float                   @default(0.7)
  category           String?
  tags               String[]                @default([])
  aliases            String[]                @default([])
  refreshCadenceDays Int                     @default(14)
  lastReviewedAt     DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  sources            KnowledgeThreadSource[]
  edges              KnowledgeThreadEdge[]

  @@index([status])
  @@index([priorityScore])
  @@index([lastReviewedAt])
}

model KnowledgeSource {
  id            String                  @id @default(cuid())
  sourceKind    String
  sourceOwner   String?
  title         String
  url           String
  urlHash       String                  @unique
  text          String
  publishedAt   DateTime?
  fetchedAt     DateTime                @default(now())
  metadata      Json?
  threadSources KnowledgeThreadSource[]
  outgoingEdges KnowledgeThreadEdge[]   @relation("KnowledgeEdgeFromSource")
  incomingEdges KnowledgeThreadEdge[]   @relation("KnowledgeEdgeToSource")

  @@index([sourceKind])
  @@index([sourceOwner])
  @@index([publishedAt])
  @@index([fetchedAt])
  @@index([sourceKind, publishedAt])
}

model KnowledgeThreadSource {
  id             String           @id @default(cuid())
  threadId       String
  sourceId       String?
  rawPoolItemId  String?
  role           String
  relevanceScore Float            @default(0.8)
  sourceWeight   Float            @default(1.0)
  evidenceQuote  String?
  summary        String?
  metadata       Json?
  createdAt      DateTime         @default(now())
  thread         KnowledgeThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  source         KnowledgeSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  rawPoolItem    RawPoolItem?     @relation(fields: [rawPoolItemId], references: [id], onDelete: SetNull)

  @@unique([threadId, sourceId, role])
  @@unique([threadId, rawPoolItemId, role])
  @@index([threadId])
  @@index([sourceId])
  @@index([rawPoolItemId])
  @@index([role])
  @@index([relevanceScore])
  @@index([threadId, relevanceScore, createdAt])
}

model KnowledgeThreadEdge {
  id           String          @id @default(cuid())
  threadId     String
  fromSourceId String
  toSourceId   String
  relationType String
  confidence   Float           @default(0.7)
  evidenceNote String?
  createdAt    DateTime        @default(now())
  thread       KnowledgeThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  fromSource   KnowledgeSource @relation("KnowledgeEdgeFromSource", fields: [fromSourceId], references: [id], onDelete: Cascade)
  toSource     KnowledgeSource @relation("KnowledgeEdgeToSource", fields: [toSourceId], references: [id], onDelete: Cascade)

  @@unique([threadId, fromSourceId, toSourceId, relationType])
  @@index([threadId])
  @@index([fromSourceId])
  @@index([toSourceId])
  @@index([relationType])
  @@index([confidence])
  @@index([threadId, confidence, createdAt])
}

model ActivityEvent {
  id            String    @id @default(cuid())
  personId      String
  sourceItemId  String?   @unique
  eventType     String
  sourceType    String
  title         String
  summary       String?
  url           String
  occurredAt    DateTime?
  detectedAt    DateTime  @default(now())
  topics        String[]
  organizations String[]
  confidence    Float     @default(0.8)
  evidenceNote  String?
  reviewStatus  String    @default("auto")
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  person     People       @relation(fields: [personId], references: [id], onDelete: Cascade)
  sourceItem RawPoolItem? @relation(fields: [sourceItemId], references: [id], onDelete: SetNull)

  @@index([personId])
  @@index([eventType])
  @@index([sourceType])
  @@index([reviewStatus])
  @@index([occurredAt])
  @@index([detectedAt])
  @@index([personId, occurredAt])
  @@index([reviewStatus, occurredAt])
  @@index([sourceType, occurredAt])
}

model SearchDocument {
  id              String                   @id @default(cuid())
  objectType      String
  objectId        String
  canonicalKey    String                   @unique
  personId        String?
  threadId        String?
  organizationId  String?
  sourceType      String?
  title           String
  summary         String?
  text            String
  url             String?
  topics          String[]                 @default([])
  organizations   String[]                 @default([])
  publishedAt     DateTime?
  fetchedAt       DateTime?
  textHash        String
  embeddingStatus String                   @default("pending")
  metadata        Json?
  searchVector    Unsupported("tsvector")?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  chunks          ContentChunk[]

  @@unique([objectType, objectId])
  @@index([objectType])
  @@index([personId])
  @@index([threadId])
  @@index([organizationId])
  @@index([sourceType])
  @@index([publishedAt])
  @@index([fetchedAt])
  @@index([embeddingStatus])
  @@index([objectType, publishedAt])
  @@index([personId, publishedAt])
  @@index([threadId, publishedAt])
}

model ContentChunk {
  id                 String                      @id @default(cuid())
  documentId         String
  objectType         String
  objectId           String
  chunkIndex         Int
  title              String
  text               String
  tokenEstimate      Int                         @default(0)
  textHash           String
  embedding          Unsupported("vector(512)")?
  embeddingModel     String?
  embeddingUpdatedAt DateTime?
  metadata           Json?
  searchVector       Unsupported("tsvector")?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  document           SearchDocument              @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([documentId])
  @@index([objectType, objectId])
  @@index([embeddingModel])
  @@index([textHash])
}

model SearchSession {
  id                 String    @id @default(cuid())
  userId             String?
  query              String
  localHits          String[]
  wikidataCandidates Json?
  status             String    @default("pending")
  confirmedPersonId  String?
  createdAt          DateTime  @default(now())
  resolvedAt         DateTime?
  confirmedPerson    People?   @relation(fields: [confirmedPersonId], references: [id])
  user               User?     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model UserProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  peopleInterests     Json     @default("{}")
  topicInterests      Json     @default("{}")
  readCards           String[]
  savedCards          String[]
  subscribedPeople    String[]
  newsletterFrequency String   @default("none")
  newsletterEmail     String?
  lastActiveAt        DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id])
}

model NewsletterDeliveryLog {
  id                String    @id @default(cuid())
  userId            String?
  email             String
  frequency         String
  deliveryType      String    @default("weekly_digest")
  subject           String
  status            String    @default("dry_run")
  provider          String?
  providerMessageId String?
  attempts          Int       @default(0)
  payload           Json?
  errorMessage      String?
  createdAt         DateTime  @default(now())
  lastAttemptAt     DateTime?
  sentAt            DateTime?
  user              User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([status])
  @@index([provider])
  @@index([createdAt])
}

model CompareReport {
  id             String               @id @default(cuid())
  title          String
  topic          String?
  peopleIds      String[]
  status         String               @default("pending") // pending | running | completed | failed
  visibility     String               @default("public")
  summary        String?
  reportJson     Json?
  sourceSnapshot Json?
  errorMessage   String?
  createdById    String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  completedAt    DateTime?
  createdBy      User?                @relation(fields: [createdById], references: [id], onDelete: SetNull)
  events         CompareReportEvent[]

  @@index([createdById])
  @@index([status, createdAt])
  @@index([createdAt])
}

model CompareReportEvent {
  id        String        @id @default(cuid())
  reportId  String
  step      String
  status    String        @default("running") // queued | running | completed | failed
  title     String
  message   String?
  metadata  Json?
  createdAt DateTime      @default(now())
  report    CompareReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, createdAt])
  @@index([step])
}

// 访问记录表 - 用于统计人物页面访问量
model PageView {
  id        String   @id @default(cuid())
  personId  String
  visitorId String // 访客指纹（IP+UA hash，用于去重）
  userId    String? // 可选：登录用户ID
  sessionId String? // 可选：匿名用户会话ID
  referrer  String? // 来源页面
  viewedAt  DateTime @default(now())
  person    People   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@index([viewedAt])
  @@index([personId, viewedAt])
  @@index([personId, visitorId, viewedAt])
}

// 人物关系表 - 记录人物之间的关系（导师、学生、联创等）
model PersonRelation {
  id              String   @id @default(cuid())
  personId        String
  relatedPersonId String
  relationType    String // advisor, advisee, cofounder, colleague, former_colleague, collaborator, successor
  description     String?
  source          String   @default("wikidata")
  confidence      Float    @default(1.0)
  reviewStatus    String   @default("needs_review") // trusted, confirmed, needs_review
  evidenceUrl     String?
  evidenceNote    String?
  createdAt       DateTime @default(now())

  person        People @relation("PersonRelations", fields: [personId], references: [id], onDelete: Cascade)
  relatedPerson People @relation("RelatedPersons", fields: [relatedPersonId], references: [id], onDelete: Cascade)

  @@unique([personId, relatedPersonId, relationType])
  @@index([personId])
  @@index([relatedPersonId])
  @@index([reviewStatus])
  @@index([personId, reviewStatus, confidence])
  @@index([relatedPersonId, reviewStatus, confidence])
  @@index([reviewStatus, createdAt])
}

// 课程表 - 记录人物开设/主讲的公开课程
model Course {
  id       String  @id @default(cuid())
  personId String
  title    String
  titleZh  String? // 中文标题
  platform String // coursera, edx, youtube, udacity, fast.ai, stanford, mit, udemy
  url      String
  urlHash  String  @unique // URL 去重

  // 课程分类
  type     String // free, paid, freemium
  level    String? // beginner, intermediate, advanced
  category String? // ml, dl, nlp, cv, rl, llm, other

  // 课程信息
  description  String?
  thumbnailUrl String?
  duration     String? // "12 weeks", "40 hours", "25 lectures"
  language     String? // en, zh, etc.

  // 统计数据
  enrollments Int? // 学员数
  rating      Float? // 评分 (0-5)
  reviewCount Int? // 评价数

  // 学习路径
  prerequisite  String? // 先修条件
  learningOrder Int? // 推荐学习顺序 (1, 2, 3...)

  // 话题标签
  topics String[] // AI话题：Deep Learning, NLP, Computer Vision, etc.

  // 数据来源和质量
  source     String  @default("perplexity") // perplexity, youtube, manual, wikidata
  verified   Boolean @default(false) // 是否人工验证
  confidence Float   @default(0.8) // 数据置信度 0-1

  // 发布时间
  publishedAt   DateTime?
  lastUpdatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  person People @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@index([platform])
  @@index([type])
  @@index([level])
}

/// 清洗审计日志: 记录每条 item 在各清洗阶段的决策, 用于回溯/度量/数据飞轮
model QAAuditLog {
  id          String   @id @default(cuid())
  personId    String
  url         String
  urlHash     String
  sourceType  String
  stage       String // L0(规则) | L1(语义) | L2(模糊去重)
  verdict     String // keep | reject | review | duplicate
  // L1 语义评分 (L0/L2 可空)
  aboutPerson Float?
  aiRelevant  Float?
  quality     Float?
  reason      String?
  createdAt   DateTime @default(now())

  @@index([personId])
  @@index([verdict])
  @@index([stage])
  @@index([createdAt])
}

/// 影响力评分审计日志: 记录某个评分版本对人物分数的解释、校准和应用结果
model InfluenceScoreAuditLog {
  id            String   @id @default(cuid())
  personId      String
  scoreVersion  String
  previousScore Float
  computedScore Float
  appliedScore  Float?
  dimensions    Json
  signals       Json
  weights       Json
  status        String   @default("dry_run") // dry_run | reviewed | applied | ignored
  reason        String?
  reviewer      String?
  createdAt     DateTime @default(now())
  person        People   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@index([scoreVersion])
  @@index([status])
  @@index([createdAt])
}

// 作品/产品实体：把散落在 People.products JSON 里、跨人重复的产品提炼成第一类实体。
// 一次连通 人(贡献者) / 公司(主理方) / 主题 / 话题。模型用 type=model 子类型表达，不另立实体。
model Product {
  id               String               @id @default(cuid())
  slug             String               @unique
  name             String
  aliases          String[]             @default([])
  type             String // model | app | tool | framework | architecture | lab | dataset | benchmark | other
  category         String?
  description      String?
  url              String?
  iconUrl          String?
  firstYear        Int?
  organizationId   String? // 主理公司（解析 org 名匹配 Organization）
  organizationName String? // 冗余展示，匹配不到时回退
  topics           String[]             @default([])
  threadSlugs      String[]             @default([]) // 关联主题（策展补）
  priorityScore    Float                @default(0)
  status           String               @default("active")
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  contributors     ProductContributor[]
  evidenceSources  ProductEvidenceSource[]

  @@index([type])
  @@index([organizationId])
  @@index([priorityScore])
}

model ProductContributor {
  id        String  @id @default(cuid())
  productId String
  personId  String
  role      String  @default("contributor") // creator | lead | contributor
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  person    People  @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([productId, personId])
  @@index([productId])
  @@index([personId])
}

model ProductEvidenceSource {
  id            String      @id @default(cuid())
  productId     String
  rawPoolItemId String
  role          String // paper_foundation | implementation_source | benchmark_source | docs_source
  matchReason   String
  confidence    Float       @default(0.8)
  summary       String?
  evidenceQuote String?
  reviewStatus  String      @default("auto") // auto | confirmed | rejected | needs_review
  metadata      Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  rawPoolItem   RawPoolItem @relation(fields: [rawPoolItemId], references: [id], onDelete: Cascade)

  @@unique([productId, rawPoolItemId, role])
  @@index([productId])
  @@index([rawPoolItemId])
  @@index([role])
  @@index([reviewStatus])
}
