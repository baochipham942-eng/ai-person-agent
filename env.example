# ===== 数据库 =====
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."
DATABASE_URL_UNPOOLED="postgresql://..."

# ===== 认证 =====
AUTH_SECRET=""
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:4001"
NEXT_PUBLIC_SITE_URL="http://localhost:4001"
SITE_URL="http://localhost:4001"
# 逗号分隔；这些邮箱首次注册可不填邀请码，验证后成为管理员。
INITIAL_ADMIN_EMAILS=""
# 认证邮件默认复用 Resend 和 NEWSLETTER_FROM_EMAIL；如需单独发件人可覆盖。
AUTH_EMAIL_PROVIDER="resend"
AUTH_EMAIL_FROM=""

# ===== 后台任务 / Inngest =====
# 本地开发设为 1；生产不要设置，改填 INNGEST_SIGNING_KEY。
INNGEST_DEV="1"
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ===== LLM =====
DEEPSEEK_API_KEY=""
DEEPSEEK_API_URL="https://api.deepseek.com/v1"

# ===== 数据源 =====
EXA_API_KEY=""
TAVILY_API_KEYS=""
TAVILY_SEARCH_DEPTH="basic"
TAVILY_RAW_CONTENT="text"
COMPARE_REPORT_TAVILY_MAX_CALLS="30"
XIAOMI_API_KEY=""
XIAOMI_API_URL="https://token-plan-sgp.xiaomimimo.com/v1"
MIMO_MODEL="mimo-v2.5-pro"
GOOGLE_API_KEY=""
XAI_API_KEY=""

# ===== Newsletter / 发送 =====
# 只读 dry-run / preflight 不需要打开真实发送开关；真实发送前必须由爸填真实值并确认。
# Provider 目前只支持 resend；NEWSLETTER_SEND_ENABLED 是最终发信总开关，默认必须保持 false。
NEWSLETTER_EMAIL_PROVIDER=""
NEWSLETTER_SEND_ENABLED="false"
# 退订 token 签名密钥；生产建议单独配置，未配置时会回退 AUTH_SECRET / NEXTAUTH_SECRET。
NEWSLETTER_TOKEN_SECRET=""
# Resend 已验证域名下的 sender，例如 "AI People <digest@your-domain.com>"。
NEWSLETTER_FROM_EMAIL=""
# 可选；需要能接收回复的地址。
NEWSLETTER_REPLY_TO=""
# Resend 重试次数，脚本会限制在 1-3 次。
NEWSLETTER_SEND_MAX_ATTEMPTS="2"
# Resend API key；不要提交真实值。
RESEND_API_KEY=""

# ===== 上线门禁 =====
PRODUCTION_BASE_URL=""
LAUNCH_GATE_OUTPUT_DIR="/tmp/ai-person-launch-gate-evidence"
LAUNCH_GATE_QUALITY_LIMIT="20"
LAUNCH_GATE_TIMEOUT_MS="30000"
LAUNCH_GATE_STRICT_QUALITY="false"

# ===== 生产上线编排 =====
ROLLOUT_OUTPUT_DIR="/tmp/ai-person-rollout-evidence"
ROLLOUT_BASE_URL=""
ROLLOUT_ACTIVITY_DAYS="90"
ROLLOUT_ACTIVITY_LIMIT="500"
ROLLOUT_NEWSLETTER_DAYS="7"
ROLLOUT_NEWSLETTER_LIMIT="50"
ROLLOUT_NEWSLETTER_EVENT_LIMIT="12"
ROLLOUT_INFLUENCE_LIMIT="24"
ROLLOUT_INFLUENCE_STATUS="all"
