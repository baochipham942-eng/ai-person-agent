#!/bin/bash

# 占位/捏造 URL 守卫：暂存了知识主题来源包时，拦截 example_ / example.com / placeholder 等假链
if git diff --cached --name-only | grep -q "data/knowledge-threads/.*\.candidates\.json"; then
  if ! node scripts/knowledge/check_placeholder_urls.mjs; then
    echo ""
    echo "❌ 提交被拦截：来源包含占位/捏造 URL（见上）。用真实可核实的来源替换后再提交。"
    exit 1
  fi
fi

# 检查 prisma schema 是否有变更
if git diff --cached --name-only | grep -q "prisma/schema.prisma"; then
  echo ""
  echo "⚠️  prisma/schema.prisma 已变更!"
  echo "   请检查 CLAUDE.md 中的 'Key Database Models' 部分是否需要同步更新。"
  echo ""
  echo "   提示: 只更新变更的表，不要修改其他内容。"
  echo ""
fi

exit 0
